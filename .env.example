# Polar regtest 3ノードの接続情報（Polar → ノード右クリック → View Connection → REST Host で取得）
# REST API + macaroon を使用（gRPCより導入容易）。Polar デフォルト REST ポート: 8081, 8082, 8083

# Alice
LND_ALICE_REST=https://127.0.0.1:8081
LND_ALICE_TLS_CERT_PATH=./secrets/alice/tls.cert
LND_ALICE_MACAROON_PATH=./secrets/alice/admin.macaroon

# Bob
LND_BOB_REST=https://127.0.0.1:8082
LND_BOB_TLS_CERT_PATH=./secrets/bob/tls.cert
LND_BOB_MACAROON_PATH=./secrets/bob/admin.macaroon

# Carol
LND_CAROL_REST=https://127.0.0.1:8083
LND_CAROL_TLS_CERT_PATH=./secrets/carol/tls.cert
LND_CAROL_MACAROON_PATH=./secrets/carol/admin.macaroon

# ポーリング間隔(秒)
POLL_INTERVAL=3

LOG_LEVEL=INFO

# bitcoind RPC (Polar 単体実行時用。compose では app サービスで上書き)
# Polar UI → bitcoind → Connect から RPC Host/User/Pass 取得
BITCOIND_RPC_URL=http://127.0.0.1:18443
BITCOIND_RPC_USER=polaruser
BITCOIND_RPC_PASS=polarpass
